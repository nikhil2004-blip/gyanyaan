# MongoDB Atlas or local connection string
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/gyanyaan?retryWrites=true&w=majority

# Secret key for signing JWTs — use a long random string
JWT_SECRET=replace_with_a_long_random_secret

# Google OAuth Client ID (from Google Cloud Console)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# Server port
PORT=3000

# Frontend URL for CORS (change to your Vercel URL in production)
FRONTEND_URL=http://localhost:5173
